# See https://editorconfig.org for documentation.
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml,toml,json,md}]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

# Keep test fixtures byte-exact
[tests/fixtures/**]
trim_trailing_whitespace = false
insert_final_newline = false
