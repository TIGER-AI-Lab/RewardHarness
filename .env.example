# Copy this to .env (or `export` directly in your shell) and fill in real values.
# `.env` is gitignored; don't commit credentials.

# ---- Required: Orchestrator (Vertex AI Gemini) ----
# Service-account JSON for Vertex AI. Get one from
# console.cloud.google.com -> IAM -> Service Accounts.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# GCP project + region tied to the service account above.
GEMINI_PROJECT=your-vertexai-project-id
GEMINI_LOCATION=global   # or us-central1 / europe-west4

# ---- Optional: Hugging Face (only if downloading gated datasets) ----
# Needed for TIGER-Lab/EditReward-Bench. Set this OR run `huggingface-cli login`.
# HF_TOKEN=hf_xxx
